{
  "name": "databricks-workspace-explorer",
  "displayName": "Databricks Workspace Explorer",
  "description": "Browse Databricks workspace files in VS Code Explorer",
  "version": "0.0.1",
  "publisher": "mikaelmoise",
  "repository": {
    "type": "git",
    "url": "https://github.com/arrismo/databricks-workspace-explorer.git"
  },
  "homepage": "https://github.com/arrismo/databricks-workspace-explorer",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/arrismo/databricks-workspace-explorer/issues"
  },
  "icon": "images/dwe_logo.png",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onFileSystem:dbws",
    "onCommand:databricksWorkspace.openRoot",
    "onCommand:databricksWorkspace.openPath",
    "onCommand:databricksWorkspace.refresh",
    "onCommand:databricksWorkspace.showAuthProfile"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "databricksWorkspace.openRoot",
        "title": "Databricks: Open Workspace Explorer"
      },
      {
        "command": "databricksWorkspace.openPath",
        "title": "Databricks: Open Workspace Path"
      },
      {
        "command": "databricksWorkspace.refresh",
        "title": "Databricks: Refresh Workspace"
      },
      {
        "command": "databricksWorkspace.showAuthProfile",
        "title": "Databricks: Show Active Auth/Profile"
      }
    ],
    "configuration": {
      "title": "Databricks Workspace Explorer",
      "properties": {
        "databricksWorkspace.host": {
          "type": "string",
          "default": "",
          "description": "Databricks workspace URL, e.g. https://dbc-xxxx.cloud.databricks.com"
        },
        "databricksWorkspace.profile": {
          "type": "string",
          "default": "",
          "description": "Databricks config profile name from ~/.databrickscfg (leave empty to use Databricks CLI default profile)"
        },
        "databricksWorkspace.databricksCliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Databricks CLI binary (optional)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsx --test test/workspaceUtils.test.ts",
    "test:fs": "tsx --tsconfig test/tsconfig.json --test test/DatabricksWorkspaceFS.test.ts",
    "test:all": "npm test && npm run test:fs"
  },
  "dependencies": {
    "@databricks/sdk-experimental": "^0.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.88.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
